# Переменные для worker/docker-compose.yml (standalone-запуск воркера).
# Для общего запуска используй /docker-compose-dev.yml и /.env в корне.

# ─── NATS ───
# В проде креды в URL: nats://user:pass@host:4222
NATS_URL=nats://localhost:4222

# ─── Qdrant ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Worker replicas ───
WORKER_REPLICAS=2

# ─── Task lifecycle ───
# Хартбит "я работаю ещё" — каждые N сек обновляет ack_wait в JetStream
TASK_HEARTBEAT_SEC=10
# Жёсткий таймаут задачи — после него воркер бросает, сообщение идёт другому консьюмеру
TASK_HARD_TIMEOUT_SEC=120

# ─── Mini LLM (лирика-поиск через transformers) ───
MINI_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# ─── Whisper (self-gen synced LRC) ───
WHISPER_MODEL=base
WHISPER_COMPUTE=int8