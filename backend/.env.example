SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop

PORT=3000

# ─── Cloudflare Proxy (опционально) ───
# Если задан SC_PROXY_URL — OAuth/auth + HTTP-запросы к SC API идут через CF Worker с X-Target header
SC_PROXY_URL=

# ─── Streaming Service ───
# URL Rust streaming service для редиректа /tracks/:urn/stream
STREAMING_SERVICE_URL=http://localhost:8080

# ─── CDN / Storage (опционально) ───
# Если storage поднят внутри docker-compose-prod, CDN_BASE_URL можно не задавать:
# compose сам подставит http://storage:3000.
# Для upload/delete в storage нужен общий Bearer токен:
CDN_BASE_URL=
CDN_AUTH_TOKEN=

# ─── Telegram алерты (опционально) ───
# Уведомления при бане OAuth-аппки
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Admin API (опционально) ───
# Токен для управления OAuth-аппками (/oauth-apps), featured контентом (/admin/featured) и статистикой (/admin/stats)
ADMIN_TOKEN=
