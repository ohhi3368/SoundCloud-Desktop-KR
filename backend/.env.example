# ─── SoundCloud OAuth ───
SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── SoundCloud Proxy (опционально) ───
# SC_PROXY_URL — CF Worker с X-Target header
# SC_PROXY_FALLBACK=true — сначала прямой, при ошибке через прокси
SC_PROXY_URL=
SC_PROXY_FALLBACK=false

# ─── Database (PostgreSQL) ───
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop

# ─── Streaming Service ───
STREAMING_SERVICE_URL=http://localhost:8080

# ─── Subscriptions snapshots ───
SUBSCRIPTIONS_SNAPSHOT_DIR=./snapshots

# ─── Telegram alerts (опционально) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Admin API (опционально) ───
ADMIN_TOKEN=

# ─── Qdrant / NATS ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# NATS JetStream — шина между backend и воркерами (см. worker/AGENTS.md)
# В проде креды в URL: nats://user:pass@host:4222
NATS_URL=nats://localhost:4222

# ─── Redis (API cache) ───
REDIS_URL=redis://localhost:6379

# ─── Storage / Streaming internal pipeline ───
STORAGE_URL=http://localhost:3002
INTERNAL_TOKEN=dev-internal

# ─── SoundWave RRF fusion weights ───
SOUNDWAVE_AUDIO_WEIGHT=0.5    # tracks_mert (MuQ)
SOUNDWAVE_CLAP_WEIGHT=0.25    # tracks_clap (MuQ-MuLan)
SOUNDWAVE_LYRICS_WEIGHT=0.25  # tracks_lyrics (bge-m3)
SOUNDWAVE_ARTIST_CAP=2
SOUNDWAVE_POPULARITY_BOOST=0.01
SOUNDWAVE_SCORE_THRESHOLD=0.3

# ─── Gateway (Rust, pid-1) ───
BACKEND_WORKERS=
BACKEND_SOCKET_DIR=/run/scd
HEALTH_PATH=/health
HEALTH_INTERVAL_MS=2000
HEALTH_TIMEOUT_MS=1500
BACKOFF_MIN_MS=500
BACKOFF_MAX_MS=30000
KILL_GRACE_MS=10000

# ─── TLS / Let's Encrypt (опционально) ───
# Серты выпускает gateway (Rust binary, pid-1 в контейнере) перед стартом
# backend-воркеров. Использует TLS-ALPN-01 на :443 (как rustls-acme в streaming
# /storage). Раз в 6 часов проверяет expiry и за 3 дня до истечения сам
# обновляет сертификат + hot-reload TLS без рестарта воркеров.
TLS_ENABLED=false
# Список доменов через запятую (первый — CN, остальные — SAN).
DOMAINS=
# Контактный email для ACME-аккаунта. По умолчанию admin@<первый домен>.
ACME_EMAIL=
# Куда складывать account.key + cert.pem + key.pem (должно переживать рестарты —
# монтировать persistent volume на /var/cache/acme).
ACME_CACHE_DIR=/var/cache/acme
# true — staging-директория Let's Encrypt (для тестов, не trusted).
ACME_STAGING=false
# Порты можно переопределить при port-mapping.
TLS_HTTPS_PORT=443
# HTTP-listener для :80. TLS_HTTP_REDIRECT=true — 301 на https.
# false — те же роуты обслуживаются и по http без TLS (mixed-mode).
# TLS_HTTP_PORT=0 — :80 не открывается совсем.
TLS_HTTP_PORT=80
TLS_HTTP_REDIRECT=true
