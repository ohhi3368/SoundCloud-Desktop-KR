SOUNDCLOUD_CLIENT_ID=your_client_id
SOUNDCLOUD_CLIENT_SECRET=your_client_secret
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop

PORT=3000

# ─── SoundCloud Cookies (опционально) ───
# HTTP cookies для cookie-based стриминга (Go+ HQ).
# Скопируй из браузера (DevTools → Application → Cookies → soundcloud.com).
# Формат: "cookie1=value1; cookie2=value2"
SC_COOKIES=

# ─── Public API v2 (опционально) ───
# false — отключает cookies и anon стримы, треки только через OAuth API / CDN
SC_PUBLIC_API_ENABLED=true

# ─── Cloudflare Proxy (опционально) ───
# Если задан SC_PROXY_URL — OAuth/auth + HTTP-запросы к SC API идут через CF Worker с X-Target header
SC_PROXY_URL=
# Если задан SC_STREAM_PROXY_URL — reverse proxy для стриминга, soundcloud.com / api-v2 / HLS / сегментов
# Если пусто — стриминг использует SC_PROXY_URL для обратной совместимости
SC_STREAM_PROXY_URL=
# ─── CDN (опционально) ───
# SecureServe CDN для кэширования аудио
CDN_BASE_URL=
CDN_AUTH_TOKEN=
CDN_UNAVAILABLE_THRESHOLD=3
CDN_UNAVAILABLE_COOLDOWN_MS=60000

# ─── Telegram алерты (опционально) ───
# Уведомления при бане OAuth-аппки
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Admin API (опционально) ───
# Токен для управления OAuth-аппками (/oauth-apps) и featured контентом (/admin/featured)
ADMIN_TOKEN=
